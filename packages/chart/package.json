{
  "name": "@domphy/chart",
  "version": "0.2.1",
  "description": "ECharts-grade chart library for Domphy. SVG-native, tone/density cascade.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "chart",
    "visualization",
    "svg",
    "echarts"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/chart"
  },
  "peerDependencies": {
    "@domphy/core": "workspace:^",
    "@domphy/theme": "workspace:^"
  },
  "dependencies": {
    "@domphy/floating": "workspace:^",
    "@luma.gl/core": "^9.1.4",
    "@luma.gl/webgl": "^9.1.4",
    "@luma.gl/engine": "^9.1.4",
    "@luma.gl/shadertools": "^9.1.4"
  },
  "devDependencies": {
    "@domphy/core": "workspace:*",
    "@domphy/theme": "workspace:*",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
