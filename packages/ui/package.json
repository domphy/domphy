{
  "name": "@domphy/ui",
  "version": "0.19.0",
  "description": "Domphy UI",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "theme",
    "ui",
    "patch"
  ],
  "author": "Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/ui"
  },
  "devDependencies": {
    "@domphy/core": "workspace:*",
    "@domphy/theme": "workspace:*",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@domphy/core": "workspace:^",
    "@domphy/theme": "workspace:^"
  },
  "dependencies": {
    "@domphy/floating": "workspace:^"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "unpkg": "dist/core-theme-ui.global.js",
  "jsdelivr": "dist/core-theme-ui.global.js"
}
