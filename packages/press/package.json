{
  "name": "@domphy/press",
  "version": "0.20.12",
  "description": "Domphy Press — VitePress-baseline static doc site framework built on @domphy/app + @domphy/markdown",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "domphy-press": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./browser": {
      "import": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "press",
    "docs",
    "static-site",
    "vitepress",
    "markdown"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/press"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "remark": "^15.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.29.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "@domphy/app": "workspace:^",
    "@domphy/core": "workspace:^",
    "@domphy/markdown": "workspace:^",
    "@domphy/theme": "workspace:^",
    "@domphy/ui": "workspace:^"
  },
  "devDependencies": {
    "@domphy/app": "workspace:*",
    "@domphy/core": "workspace:*",
    "@domphy/markdown": "workspace:*",
    "@domphy/theme": "workspace:*",
    "@domphy/ui": "workspace:*",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
