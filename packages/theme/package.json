{
  "name": "@domphy/theme",
  "version": "0.20.1",
  "description": "Domphy design system — reactive color/spacing/size tokens, tone ramps, and theme generation from a single base color per role",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "theme",
    "design-system",
    "design-tokens",
    "color",
    "dark-mode"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/theme"
  },
  "dependencies": {
    "@domphy/palette": "workspace:^"
  },
  "devDependencies": {
    "@domphy/core": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@domphy/core": "workspace:^"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "unpkg": "dist/core-theme.global.js",
  "jsdelivr": "dist/core-theme.global.js"
}
