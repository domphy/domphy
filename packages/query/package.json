{
  "name": "@domphy/query",
  "version": "0.3.0",
  "description": "Domphy Query - async state management, a 1-1 port of @tanstack/query-core",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "query",
    "async",
    "cache",
    "fetch"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/query"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "unpkg": "dist/query.global.js",
  "jsdelivr": "dist/query.global.js"
}
