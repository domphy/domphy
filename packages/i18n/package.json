{
  "name": "@domphy/i18n",
  "version": "0.19.2",
  "description": "Domphy i18n — generic i18next wrapper with reactive Domphy integration (globalThis dedup, typed keys, t(listener, key) overload)",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "node ../../scripts/guard-pnpm-publish.mjs && npm run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "i18n",
    "i18next",
    "reactivity"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/i18n"
  },
  "dependencies": {
    "i18next": "^25.0.0"
  },
  "peerDependencies": {
    "@domphy/core": "workspace:^"
  },
  "devDependencies": {
    "@domphy/core": "workspace:*",
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ]
}
