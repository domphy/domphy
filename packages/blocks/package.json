{
  "name": "@domphy/blocks",
  "version": "0.1.0",
  "description": "Large composed UI blocks for Domphy — dashboards, auth pages, sidebars, chart recipes, and marketing/effect components, independently reimplemented (clean-room) from the public behavior of shadcn/ui, Magic UI, and Aceternity UI.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "vite --config vite.demo.config.ts",
    "visual-compare": "tsx scripts/visual-compare.ts"
  },
  "keywords": [
    "domphy",
    "blocks",
    "ui",
    "dashboard",
    "components"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/blocks"
  },
  "peerDependencies": {
    "@domphy/core": "workspace:^",
    "@domphy/theme": "workspace:^",
    "@domphy/ui": "workspace:^",
    "@domphy/chart": "workspace:^",
    "@domphy/form": "workspace:^",
    "@domphy/table": "workspace:^"
  },
  "dependencies": {
    "cobe": "^0.6.3",
    "canvas-confetti": "^1.9.3",
    "rough-notation": "^0.5.1"
  },
  "devDependencies": {
    "@domphy/core": "workspace:*",
    "@domphy/theme": "workspace:*",
    "@domphy/ui": "workspace:*",
    "@domphy/chart": "workspace:*",
    "@domphy/form": "workspace:*",
    "@domphy/table": "workspace:*",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.9.2",
    "jsdom": "^29.1.1",
    "playwright": "^1.49.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
