{
  "name": "@domphy/table",
  "version": "0.13.0",
  "description": "Domphy Table - headless table logic, a 1-1 port of @tanstack/table-core",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./domphy": {
      "import": {
        "types": "./dist/domphy.d.ts",
        "default": "./dist/domphy.js"
      },
      "require": {
        "types": "./dist/domphy.d.cts",
        "default": "./dist/domphy.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "table",
    "datagrid",
    "headless"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/table"
  },
  "peerDependencies": {
    "@domphy/core": "workspace:^"
  },
  "devDependencies": {
    "@domphy/core": "workspace:*",
    "@types/node": "^25.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "unpkg": "dist/table.global.js",
  "jsdelivr": "dist/table.global.js"
}
