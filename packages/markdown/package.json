{
  "name": "@domphy/markdown",
  "version": "0.19.0",
  "description": "Domphy Markdown - parse Markdown (remark/MDAST) into Domphy element trees for SSR with @domphy/core",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "markdown",
    "remark",
    "ssr",
    "frontmatter",
    "toc"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/markdown"
  },
  "dependencies": {
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "unified": "^11.0.5",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "@domphy/core": "workspace:^"
  },
  "devDependencies": {
    "@domphy/core": "workspace:*",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "unpkg": "dist/markdown.global.js",
  "jsdelivr": "dist/markdown.global.js"
}
