{
  "name": "@domphy/dnd",
  "version": "0.18.1",
  "description": "Domphy Drag & Drop - reactive adapter for the framework-agnostic @formkit/drag-and-drop engine",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pack": "tsup && npm pack",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "domphy",
    "drag-and-drop",
    "dnd",
    "sortable",
    "reorder"
  ],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domphy/domphy.git",
    "directory": "packages/dnd"
  },
  "dependencies": {
    "@formkit/drag-and-drop": "^0.6.0"
  },
  "peerDependencies": {
    "@domphy/core": "workspace:^"
  },
  "devDependencies": {
    "@domphy/core": "workspace:*",
    "@types/node": "^25.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "unpkg": "dist/dnd.global.js",
  "jsdelivr": "dist/dnd.global.js"
}
