{
  "name": "domphy-web",
  "version": "1.0.0",
  "description": "Domphy website",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "llms": "node scripts/llms-full.mjs",
    "manifest": "node scripts/manifest.mjs",
    "app-manifest": "node scripts/app-manifest.mjs",
    "test": "vitest run",
    "dev": "tsx ../../packages/press/dist/cli.js dev --port 3000",
    "preview": "tsx serve.press.ts",
    "build": "pnpm --filter \"@domphy/*\" build && node scripts/manifest.mjs && node scripts/app-manifest.mjs && node scripts/llms-full.mjs && tsx build.press.ts",
    "a11y": "node scripts/a11y-audit.mjs",
    "a11y:prod": "node scripts/a11y-audit.mjs https://domphy.com https://domphy.com/docs/quickstart https://domphy.com/docs/ui/patches/button",
    "visual": "playwright test -c visual/playwright.config.ts",
    "visual:update": "playwright test -c visual/playwright.config.ts --update-snapshots",
    "visual:patches": "playwright test -c visual/playwright.config.ts --grep \"patches catalog\"",
    "visual:patches:update": "playwright test -c visual/playwright.config.ts --grep \"patches catalog\" --update-snapshots",
    "visual:blocks-gen": "node scripts/gen-visual-blocks.mjs",
    "visual:serve": "node visual/serve-standalone.mjs --port 4177",
    "postinstall": "puppeteer browsers install chrome-headless-shell"
  },
  "keywords": [],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/puppeteer": "^4.12.1",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@domphy/app": "workspace:*",
    "@domphy/blocks": "workspace:*",
    "@domphy/chart": "workspace:*",
    "@domphy/core": "workspace:*",
    "@domphy/dnd": "workspace:*",
    "@domphy/doctor": "workspace:*",
    "@domphy/floating": "workspace:*",
    "@domphy/form": "workspace:*",
    "@domphy/i18n": "workspace:*",
    "@domphy/markdown": "workspace:*",
    "@domphy/mermaid": "workspace:*",
    "@domphy/palette": "workspace:*",
    "@domphy/press": "workspace:*",
    "@domphy/query": "workspace:*",
    "@domphy/router": "workspace:*",
    "@domphy/table": "workspace:*",
    "@domphy/theme": "workspace:*",
    "@domphy/three": "workspace:*",
    "@domphy/ui": "workspace:*",
    "@domphy/virtual": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@tanstack/query-core": "^5.90.20",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^2.0.10",
    "@types/sortablejs": "^1.15.9",
    "axe-core": "^4.12.1",
    "codemirror": "^6.0.2",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.1.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-include": "^2.0.0",
    "mermaid": "^11.0.0",
    "page": "^1.11.6",
    "puppeteer": "^24.37.5",
    "shiki": "^1.29.2",
    "sortablejs": "^1.15.7",
    "sucrase": "^3.35.1",
    "three": "^0.180.0",
    "tsx": "^4.19.2",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
