{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!reference",
      "!reference",
      "!paper",
      "!paper",
      "!bench/generated.json",
      "!packages/query/src",
      "!packages/table/src",
      "!packages/router/src",
      "!packages/router/tests",
      "!packages/virtual/src",
      "!packages/form/src",
      "!packages/floating/src",
      "!packages/palette/src"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      },
      "complexity": {
        "useOptionalChain": "off",
        "noImportantStyles": "off",
        "noBannedTypes": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "useIterableCallbackReturn": "off"
      },
      "correctness": {
        "noInnerDeclarations": "off",
        "noUnusedVariables": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "apps/web/docs/demos/**",
        "apps/web/docs/editor/**",
        "apps/web/docs/preview/**",
        "**/*.test.ts",
        "packages/ui/src/utils/floating.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" },
          "style": { "noNonNullAssertion": "off" }
        }
      }
    }
  ]
}
