{
  "name": "domphy",
  "description": "A composable UI framework.",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "check": "biome check .",
    "fix": "biome check --write .",
    "publish:core": "cd packages/core && pnpm publish --access public --no-git-checks",
    "publish:theme": "cd packages/theme && pnpm publish --access public --no-git-checks",
    "publish:ui": "cd packages/ui && pnpm publish --access public --no-git-checks",
    "publish:app": "cd packages/app && pnpm publish --access public --no-git-checks",
    "publish:query": "cd packages/query && pnpm publish --access public --no-git-checks",
    "publish:table": "cd packages/table && pnpm publish --access public --no-git-checks",
    "publish:router": "cd packages/router && pnpm publish --access public --no-git-checks",
    "publish:virtual": "cd packages/virtual && pnpm publish --access public --no-git-checks",
    "publish:form": "cd packages/form && pnpm publish --access public --no-git-checks",
    "publish:dnd": "cd packages/dnd && pnpm publish --access public --no-git-checks",
    "publish:blocks": "cd packages/blocks && pnpm publish --access public --no-git-checks",
    "publish:floating": "cd packages/floating && pnpm publish --access public --no-git-checks",
    "publish:palette": "cd packages/palette && pnpm publish --access public --no-git-checks",
    "publish:doctor": "cd packages/doctor && pnpm publish --access public --no-git-checks",
    "publish:markdown": "cd packages/markdown && pnpm publish --access public --no-git-checks",
    "publish:mermaid": "cd packages/mermaid && pnpm publish --access public --no-git-checks",
    "publish:mcp": "cd packages/mcp && pnpm publish --access public --no-git-checks",
    "publish:three": "cd packages/three && pnpm publish --access public --no-git-checks",
    "publish:create-domphy": "cd packages/create-domphy && pnpm publish --access public --no-git-checks",
    "bench": "pnpm --filter bench bench",
    "bench:dry": "pnpm --filter bench bench:dry"
  },
  "repository": "git+https://github.com/domphy/domphy.git",
  "keywords": [],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  },
  "version": "0.18.0"
}
