{
  "name": "domphy",
  "description": "A composable UI framework.",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "check": "biome check .",
    "fix": "biome check --write .",
    "publish:core": "cd packages/core && pnpm publish --access public --no-git-checks",
    "publish:theme": "cd packages/theme && pnpm publish --access public --no-git-checks",
    "publish:ui": "cd packages/ui && pnpm publish --access public --no-git-checks"
  },
  "repository": "git+https://github.com/domphy/domphy.git",
  "keywords": [],
  "author": "Huu Khanh Nguyen",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  },
  "version": "0.0.1"
}
